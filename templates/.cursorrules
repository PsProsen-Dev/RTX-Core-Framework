{
  "name": "RTX-Core-Cursor-Integration",
  "description": "Enforces global RTX framework parameters directly inside the Cursor IDE chat panel and inline composer context tabs.",
  "settings": {
    "rules_path": "RTX-Core-Framework.md",
    "prevent_default_formatting": true,
    "temperature": 0.3
